PORT=3001

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA&connection_limit=15
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public&connection_limit=15"

# Database connection for Worker (separate pool to prevent exhausting connections)
DATABASE_URL_WORKER="postgresql://user:password@localhost:5432/db_name?schema=public&connection_limit=10"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# ============================================================
# SECURITY — BẮT BUỘC PHẢI ĐẶT GIÁ TRỊ THẬT Ở PRODUCTION
# ============================================================
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="1d" # Thời gian hết hạn của JWT, ví dụ: 15m, 1h, 1d

WEBHOOK_SECRET="your-webhook-secret-here"

# Secret cho internal worker routes (ngăn request từ bên ngoài)
INTERNAL_WORKER_SECRET="your-internal-worker-secret"

# CORS — Danh sách origin được phép (phân cách bằng dấu phẩy)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173"

# SMTP (cho Nodemailer) — Điền thông tin thật ở production
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="TicketBox <noreply@ticketbox.vn>"

# Gemini API Key (tuỳ chọn — để bỏ trống sẽ dùng fallback)
GEMINI_API_KEY=""

# VNPAY Sandbox configuration (optional, if using VNPAY)
VNPAY_TMN_CODE="YOUR_TMN_CODE"
VNPAY_HASH_SECRET="YOUR_HASH_SECRET"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:5173/checkout/callback"
