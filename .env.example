PORT=3001

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://user:password@localhost:5432/ticketbox_db?schema=public"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# ============================================================
# SECURITY — BẮT BUỘC PHẢI ĐẶT GIÁ TRỊ THẬT Ở PRODUCTION
# ============================================================
JWT_SECRET="your-jwt-secret-here"
WEBHOOK_SECRET="your-webhook-secret-here"

# Secret cho internal worker routes (ngăn request từ bên ngoài)
INTERNAL_WORKER_SECRET="your-internal-worker-secret"

# CORS — Danh sách origin được phép (phân cách bằng dấu phẩy)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173"

# SMTP (cho Nodemailer) — Điền thông tin thật ở production
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="TicketBox <noreply@ticketbox.vn>"

# Gemini API Key (tuỳ chọn — để bỏ trống sẽ dùng fallback)
GEMINI_API_KEY=""
